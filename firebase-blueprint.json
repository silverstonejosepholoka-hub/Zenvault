{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user account details and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "currency": { "type": "string" },
        "createdAt": { "type": "number" },
        "securitySetup": { "type": "boolean" }
      },
      "required": ["uid", "currency", "createdAt"]
    },
    "Account": {
      "title": "Financial Account",
      "description": "Represents a currency-specific wallet or mobile money account.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "currency": { "type": "string" },
        "balance": { "type": "number" },
        "label": { "type": "string" },
        "type": { "type": "string", "enum": ["wallet", "mobile_money", "bank"] }
      },
      "required": ["userId", "currency", "balance", "type"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Record of a financial movement.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "accountId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "type": { "type": "string", "enum": ["credit", "debit"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["completed", "pending", "failed"] }
      },
      "required": ["userId", "accountId", "amount", "currency", "type", "category", "timestamp", "status"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Spending limits for a category.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "limit": { "type": "number" },
        "spent": { "type": "number" },
        "currency": { "type": "string" },
        "period": { "type": "string", "enum": ["monthly", "weekly"] }
      },
      "required": ["userId", "category", "limit", "spent", "currency", "period"]
    },
    "Goal": {
      "title": "Savings Goal",
      "description": "A target to save for.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "targetAmount": { "type": "number" },
        "currentAmount": { "type": "number" },
        "currency": { "type": "string" },
        "deadline": { "type": "number" }
      },
      "required": ["userId", "title", "targetAmount", "currentAmount", "currency"]
    },
    "VirtualCard": {
      "title": "Virtual Card",
      "description": "Virtual credit card details.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "cardNumber": { "type": "string" },
        "expiryDate": { "type": "string" },
        "cvv": { "type": "string" },
        "cardHolder": { "type": "string" },
        "isActive": { "type": "boolean" },
        "type": { "type": "string", "enum": ["visa", "mastercard"] }
      },
      "required": ["userId", "cardNumber", "expiryDate", "cvv", "cardHolder", "isActive", "type"]
    },
    "PriceAlert": {
      "title": "Price Alert",
      "description": "Stock price notification trigger.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "symbol": { "type": "string" },
        "targetPrice": { "type": "number" },
        "condition": { "type": "string", "enum": ["above", "below"] },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "symbol", "targetPrice", "condition", "isActive", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profile document."
    },
    "/accounts/{accountId}": {
      "schema": "Account",
      "description": "Financial account document."
    },
    "/transactions/{txId}": {
      "schema": "Transaction",
      "description": "Transaction record."
    },
    "/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Budget limit document."
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Savings goal document."
    },
    "/cards/{cardId}": {
      "schema": "VirtualCard",
      "description": "Virtual card document."
    },
    "/priceAlerts/{alertId}": {
      "schema": "PriceAlert",
      "description": "Stock price alert document."
    }
  }
}
